# ── Interfaces ──
TELEGRAM_ENABLED=true
TELEGRAM_BOT_TOKEN=
API_ENABLED=true
API_PORT=3000
API_KEY=
CLI_ENABLED=true

# ── Auth ──
SINGLE_USER_MODE=false
TELEGRAM_ALLOWED_USERS=           # Comma-separated IDs (empty = open)

# ── Providers ──
DEFAULT_PROVIDER=claude-cli
CLAUDE_BIN=claude
CLAUDE_SKIP_PERMISSIONS=false
GEMINI_BIN=gemini
CODEX_BIN=codex
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
GOOGLE_API_KEY=
OPENROUTER_API_KEY=
OPENROUTER_MODEL=anthropic/claude-sonnet-4  # Any model from openrouter.ai/models

# ── Vault ──
VAULT_PATH=./vault
DATA_PATH=./data

# ── Synthesis ──
SYNTHESIS_ENABLED=true
SYNTHESIS_SCHEDULE=0 9 * * 0      # Weekly Sunday 9am
SYNTHESIS_PROVIDER=claude-cli

# ── General ──
RESPONSE_TIMEOUT_MS=300000
LOG_LEVEL=info
